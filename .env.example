# Local development settings. Copy this file to .env and fill in real values.

# Server
PORT=3000
SQLITE_DB_PATH=data/tracker.db
SQLITE3_PATH=sqlite3

# football-data.org
FOOTBALL_DATA_API_KEY=your-football-data-token
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION=WC
FOOTBALL_DATA_SEASON=2026
FOOTBALL_DATA_SYNC_MODE=competition
FOOTBALL_DATA_DATE_WINDOW_DAYS=3
FOOTBALL_DATA_SYNC_MINUTES=15
FOOTBALL_DATA_AUTO_SYNC=true

# Local-only workaround if Node reports UNABLE_TO_VERIFY_LEAF_SIGNATURE.
# Do not enable this in production/Railway.
FOOTBALL_DATA_ALLOW_INSECURE_TLS=false
