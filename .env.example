# Local development settings. Copy this file to .env and fill in real values.

# Server
PORT=3000
SQLITE_DB_PATH=data/tracker.db
SQLITE3_PATH=sqlite3

# API-Football
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE=1
API_FOOTBALL_SEASON=2026
API_FOOTBALL_SYNC_MODE=auto
API_FOOTBALL_DATE_WINDOW_DAYS=3
API_FOOTBALL_SYNC_MINUTES=15
API_FOOTBALL_AUTO_SYNC=true

# Local-only workaround if Node reports UNABLE_TO_VERIFY_LEAF_SIGNATURE.
# Do not enable this in production/Railway.
API_FOOTBALL_ALLOW_INSECURE_TLS=false
